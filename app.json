{
  "expo": {
    "name": "SkyCast",
    "slug": "SkyCast",
    "version": "1.0.0",
    "scheme": "skycast",
    "icon": "./assets/icon.png",
    "orientation": "default",
    "userInterfaceStyle": "automatic",
    "plugins": [
      "expo-router",
      "expo-screen-orientation",
      "expo-location",
      "expo-sensors",
      "expo-status-bar"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "ios": {
      "bundleIdentifier": "dev.christopherjbaker.skycast",
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "dev.christopherjbaker.skycast",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2e7fab2b-8ca9-4fd0-941c-d3972eba063b"
      }
    }
  }
}
